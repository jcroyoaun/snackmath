{{define "page:title"}}snackmath{{end}}

{{define "page:meta"}}
<meta name="page" content="home">
<meta name="description" content="Compare calorie density between two foods">
{{end}}

{{define "page:main"}}
<form method="GET" action="/" class="space-y-5">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <fieldset class="rounded-lg bg-zinc-900 p-5 space-y-4 {{if .Result}}{{if eq .Result.Winner "A"}}ring-2 ring-emerald-500/60{{else if eq .Result.Winner "B"}}ring-1 ring-zinc-700{{end}}{{end}}">
            <legend class="text-base font-medium text-zinc-400 px-1">Item A</legend>
            <input type="text" name="name_a" placeholder="Name (optional)"
                value="{{if .Result}}{{if ne .Result.ItemA.Name "Item A"}}{{.Result.ItemA.Name}}{{end}}{{end}}"
                class="w-full bg-zinc-800 rounded-md border-none text-zinc-200 px-4 py-3 text-base focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-600">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm text-zinc-500 mb-1">Grams</label>
                    <input type="text" name="grams_a" required inputmode="decimal"
                        value="{{if .Result}}{{formatFloat .Result.ItemA.PortionSize 1}}{{end}}"
                        class="w-full bg-zinc-800 rounded-md border-none text-zinc-100 px-4 py-3.5 text-2xl font-semibold focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-700"
                        placeholder="0">
                </div>
                <div>
                    <label class="block text-sm text-zinc-500 mb-1">Calories</label>
                    <input type="text" name="cal_a" required inputmode="decimal"
                        value="{{if .Result}}{{formatFloat .Result.ItemA.Calories 1}}{{end}}"
                        class="w-full bg-zinc-800 rounded-md border-none text-zinc-100 px-4 py-3.5 text-2xl font-semibold focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-700"
                        placeholder="0">
                </div>
            </div>
        </fieldset>

        <fieldset class="rounded-lg bg-zinc-900 p-5 space-y-4 {{if .Result}}{{if eq .Result.Winner "B"}}ring-2 ring-emerald-500/60{{else if eq .Result.Winner "A"}}ring-1 ring-zinc-700{{end}}{{end}}">
            <legend class="text-base font-medium text-zinc-400 px-1">Item B</legend>
            <input type="text" name="name_b" placeholder="Name (optional)"
                value="{{if .Result}}{{if ne .Result.ItemB.Name "Item B"}}{{.Result.ItemB.Name}}{{end}}{{end}}"
                class="w-full bg-zinc-800 rounded-md border-none text-zinc-200 px-4 py-3 text-base focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-600">
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm text-zinc-500 mb-1">Grams</label>
                    <input type="text" name="grams_b" required inputmode="decimal"
                        value="{{if .Result}}{{formatFloat .Result.ItemB.PortionSize 1}}{{end}}"
                        class="w-full bg-zinc-800 rounded-md border-none text-zinc-100 px-4 py-3.5 text-2xl font-semibold focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-700"
                        placeholder="0">
                </div>
                <div>
                    <label class="block text-sm text-zinc-500 mb-1">Calories</label>
                    <input type="text" name="cal_b" required inputmode="decimal"
                        value="{{if .Result}}{{formatFloat .Result.ItemB.Calories 1}}{{end}}"
                        class="w-full bg-zinc-800 rounded-md border-none text-zinc-100 px-4 py-3.5 text-2xl font-semibold focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-700"
                        placeholder="0">
                </div>
            </div>
        </fieldset>

    </div>

    <details class="rounded-lg bg-zinc-900 text-sm"
        {{if .Result}}{{if .Result.HasMacros}}open{{end}}{{end}}>
        <summary class="px-5 py-3 cursor-pointer text-zinc-500 hover:text-zinc-300 select-none text-base">
            Macros (optional)
        </summary>
        <div class="grid grid-cols-2 gap-5 px-5 pb-5">
            <div>
                <p class="text-sm text-zinc-500 mb-2">Item A</p>
                <div class="grid grid-cols-3 gap-2">
                    <div>
                        <label class="block text-xs text-zinc-600 mb-0.5">Prot</label>
                        <input type="text" name="prot_a" inputmode="decimal"
                            value="{{if .Result}}{{if gt .Result.ItemA.Protein 0.0}}{{formatFloat .Result.ItemA.Protein 1}}{{end}}{{end}}"
                            class="w-full bg-zinc-800 rounded-md border-none text-zinc-200 px-3 py-2.5 text-base focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-700"
                            placeholder="g">
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-600 mb-0.5">Carbs</label>
                        <input type="text" name="carbs_a" inputmode="decimal"
                            value="{{if .Result}}{{if gt .Result.ItemA.Carbs 0.0}}{{formatFloat .Result.ItemA.Carbs 1}}{{end}}{{end}}"
                            class="w-full bg-zinc-800 rounded-md border-none text-zinc-200 px-3 py-2.5 text-base focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-700"
                            placeholder="g">
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-600 mb-0.5">Fat</label>
                        <input type="text" name="fat_a" inputmode="decimal"
                            value="{{if .Result}}{{if gt .Result.ItemA.Fat 0.0}}{{formatFloat .Result.ItemA.Fat 1}}{{end}}{{end}}"
                            class="w-full bg-zinc-800 rounded-md border-none text-zinc-200 px-3 py-2.5 text-base focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-700"
                            placeholder="g">
                    </div>
                </div>
            </div>
            <div>
                <p class="text-sm text-zinc-500 mb-2">Item B</p>
                <div class="grid grid-cols-3 gap-2">
                    <div>
                        <label class="block text-xs text-zinc-600 mb-0.5">Prot</label>
                        <input type="text" name="prot_b" inputmode="decimal"
                            value="{{if .Result}}{{if gt .Result.ItemB.Protein 0.0}}{{formatFloat .Result.ItemB.Protein 1}}{{end}}{{end}}"
                            class="w-full bg-zinc-800 rounded-md border-none text-zinc-200 px-3 py-2.5 text-base focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-700"
                            placeholder="g">
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-600 mb-0.5">Carbs</label>
                        <input type="text" name="carbs_b" inputmode="decimal"
                            value="{{if .Result}}{{if gt .Result.ItemB.Carbs 0.0}}{{formatFloat .Result.ItemB.Carbs 1}}{{end}}{{end}}"
                            class="w-full bg-zinc-800 rounded-md border-none text-zinc-200 px-3 py-2.5 text-base focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-700"
                            placeholder="g">
                    </div>
                    <div>
                        <label class="block text-xs text-zinc-600 mb-0.5">Fat</label>
                        <input type="text" name="fat_b" inputmode="decimal"
                            value="{{if .Result}}{{if gt .Result.ItemB.Fat 0.0}}{{formatFloat .Result.ItemB.Fat 1}}{{end}}{{end}}"
                            class="w-full bg-zinc-800 rounded-md border-none text-zinc-200 px-3 py-2.5 text-base focus:outline-none focus:ring-1 focus:ring-zinc-600 placeholder-zinc-700"
                            placeholder="g">
                    </div>
                </div>
            </div>
        </div>
    </details>

    <div class="flex gap-3">
        <button type="submit"
            class="flex-1 py-4 bg-emerald-600 text-white rounded-lg text-lg font-semibold
                   hover:bg-emerald-500 active:bg-emerald-700 transition-colors">
            Compare
        </button>
        {{if .Result}}
        <a href="/"
            class="flex items-center justify-center px-6 py-4 rounded-lg bg-zinc-800 text-blue-400 text-base font-medium
                   hover:bg-zinc-700 transition-colors">
            Clear
        </a>
        {{end}}
    </div>

</form>

{{if .Result}}
<div class="mt-8 rounded-lg bg-zinc-900 overflow-hidden">

    <div class="px-5 py-5 text-center border-b border-zinc-800">
        {{if eq .Result.Winner "TIE"}}
            <p class="text-zinc-400 text-base">Same calorie density -- it's a tie.</p>
        {{else}}
            <p class="text-2xl font-semibold text-emerald-400">{{.Result.WinnerItem}} wins</p>
            <p class="text-zinc-500 text-sm mt-1">lower calorie density per 100g</p>
        {{end}}
    </div>

    <table class="w-full">
        <thead>
            <tr class="text-sm text-zinc-500">
                <th class="py-3 px-5 text-left font-medium">per 100g</th>
                <th class="py-3 px-5 text-right font-medium {{if eq .Result.Winner "A"}}text-emerald-400{{end}}">{{.Result.ItemA.Name}}</th>
                <th class="py-3 px-5 text-right font-medium {{if eq .Result.Winner "B"}}text-emerald-400{{end}}">{{.Result.ItemB.Name}}</th>
            </tr>
        </thead>
        <tbody class="text-zinc-200">
            <tr class="border-t border-zinc-800">
                <td class="py-3.5 px-5 text-zinc-400 text-base">Calories</td>
                <td class="py-3.5 px-5 text-right font-semibold text-2xl {{if eq .Result.Winner "A"}}text-emerald-400{{end}}">{{formatFloat .Result.ItemA.CalsPer100g 1}}</td>
                <td class="py-3.5 px-5 text-right font-semibold text-2xl {{if eq .Result.Winner "B"}}text-emerald-400{{end}}">{{formatFloat .Result.ItemB.CalsPer100g 1}}</td>
            </tr>
            {{if .Result.HasMacros}}
            {{if or (gt .Result.ItemA.Protein 0.0) (gt .Result.ItemB.Protein 0.0)}}
            <tr class="border-t border-zinc-800/50">
                <td class="py-3 px-5 text-zinc-500">Protein</td>
                <td class="py-3 px-5 text-right text-base">{{formatFloat .Result.ItemA.ProtPer100g 1}}g</td>
                <td class="py-3 px-5 text-right text-base">{{formatFloat .Result.ItemB.ProtPer100g 1}}g</td>
            </tr>
            {{end}}
            {{if or (gt .Result.ItemA.Carbs 0.0) (gt .Result.ItemB.Carbs 0.0)}}
            <tr class="border-t border-zinc-800/50">
                <td class="py-3 px-5 text-zinc-500">Carbs</td>
                <td class="py-3 px-5 text-right text-base">{{formatFloat .Result.ItemA.CarbsPer100g 1}}g</td>
                <td class="py-3 px-5 text-right text-base">{{formatFloat .Result.ItemB.CarbsPer100g 1}}g</td>
            </tr>
            {{end}}
            {{if or (gt .Result.ItemA.Fat 0.0) (gt .Result.ItemB.Fat 0.0)}}
            <tr class="border-t border-zinc-800/50">
                <td class="py-3 px-5 text-zinc-500">Fat</td>
                <td class="py-3 px-5 text-right text-base">{{formatFloat .Result.ItemA.FatPer100g 1}}g</td>
                <td class="py-3 px-5 text-right text-base">{{formatFloat .Result.ItemB.FatPer100g 1}}g</td>
            </tr>
            {{end}}
            {{end}}
        </tbody>
    </table>

</div>
{{end}}

<div id="history" class="mt-8 hidden">
    <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-medium text-zinc-500">Recent comparisons</h2>
        <button type="button" id="clear-history" class="text-xs text-zinc-600 hover:text-zinc-400 transition-colors">clear</button>
    </div>
    <div id="history-list" class="space-y-2"></div>
</div>

<script>
(function() {
    const KEY = "snackmath_history";
    const MAX = 20;

    function load() {
        try { return JSON.parse(localStorage.getItem(KEY)) || []; }
        catch { return []; }
    }

    function save(items) {
        localStorage.setItem(KEY, JSON.stringify(items.slice(0, MAX)));
    }

    // Save current comparison
    {{if .Result}}
    (function() {
        var entry = {
            a: {{if ne .Result.ItemA.Name "Item A"}}{{printf "%q" .Result.ItemA.Name}}{{else}}""{{end}},
            b: {{if ne .Result.ItemB.Name "Item B"}}{{printf "%q" .Result.ItemB.Name}}{{else}}""{{end}},
            calA: {{formatFloat .Result.ItemA.CalsPer100g 1}},
            calB: {{formatFloat .Result.ItemB.CalsPer100g 1}},
            winner: {{printf "%q" .Result.Winner}},
            url: window.location.pathname + window.location.search,
            ts: Date.now()
        };
        var items = load();
        // Don't dupe if same URL
        if (items.length === 0 || items[0].url !== entry.url) {
            items.unshift(entry);
            save(items);
        }
    })();
    {{end}}

    // Render history
    var items = load();
    if (items.length > 0) {
        document.getElementById("history").classList.remove("hidden");
        var list = document.getElementById("history-list");
        items.forEach(function(item) {
            var a = document.createElement("a");
            a.href = item.url;
            a.className = "block rounded-lg bg-zinc-900 px-4 py-3 hover:bg-zinc-800 transition-colors";

            var nameA = item.a || "Item A";
            var nameB = item.b || "Item B";
            var winLabel = item.winner === "TIE" ? "tie" : (item.winner === "A" ? nameA : nameB);

            a.innerHTML =
                '<div class="flex items-center justify-between">' +
                    '<span class="text-sm text-zinc-300">' + esc(nameA) + ' vs ' + esc(nameB) + '</span>' +
                    '<span class="text-xs text-zinc-600">' + timeAgo(item.ts) + '</span>' +
                '</div>' +
                '<div class="flex items-center justify-between mt-1">' +
                    '<span class="text-xs text-zinc-500">' + item.calA + ' vs ' + item.calB + ' cal/100g</span>' +
                    '<span class="text-xs ' + (item.winner === "TIE" ? "text-zinc-500" : "text-emerald-500") + '">' + esc(winLabel) + '</span>' +
                '</div>';
            list.appendChild(a);
        });
    }

    document.getElementById("clear-history").addEventListener("click", function() {
        localStorage.removeItem(KEY);
        document.getElementById("history").classList.add("hidden");
    });

    function esc(s) {
        var d = document.createElement("div");
        d.textContent = s;
        return d.innerHTML;
    }

    function timeAgo(ts) {
        var s = Math.floor((Date.now() - ts) / 1000);
        if (s < 60) return "just now";
        var m = Math.floor(s / 60);
        if (m < 60) return m + "m ago";
        var h = Math.floor(m / 60);
        if (h < 24) return h + "h ago";
        var d = Math.floor(h / 24);
        return d + "d ago";
    }
})();
</script>
{{end}}
