{{define "base"}}
<!doctype html>
<html lang='en'>
    <head>
        <meta charset='utf-8'>
        <title>{{template "page:title" .}}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="theme-color" content="#09090b">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
        <link rel="manifest" href="/static/manifest.json">
        <link rel="icon" href="/static/img/icon-192.svg" type="image/svg+xml">
        <link rel="apple-touch-icon" href="/static/img/icon-192.svg">
        {{block "page:meta" .}}{{end}}
        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
        <style>body { font-family: 'Inter', sans-serif; }</style>
    </head>
    <body class="bg-zinc-950 text-zinc-200 min-h-screen flex flex-col">
        <header class="border-b border-zinc-800 px-5 py-4">
            {{template "partial:nav" .}}
        </header>
        <main class="flex-1 w-full max-w-3xl mx-auto px-5 py-6">
            {{template "page:main" .}}
        </main>
        {{template "partial:footer" .}}
        <script>
            if ("serviceWorker" in navigator) {
                navigator.serviceWorker.register("/sw.js");
            }
        </script>
    </body>
</html>
{{end}}
